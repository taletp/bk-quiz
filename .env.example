# ============================================================================
# LLM Provider Configuration
# ============================================================================
# 
# Choose ONE of the three providers below and set LLM_PROVIDER accordingly:
#   export LLM_PROVIDER=groq    # Recommended: free, fast, easy (default)
#   export LLM_PROVIDER=ollama  # Local LLM, offline use
#   export LLM_PROVIDER=openai  # Best quality, costs money
#

# ============================================================================
# OPTION 1: Groq (Recommended) ⭐
# ============================================================================
# Free, fast, unlimited requests, no setup hassles
# Get API key: https://console.groq.com/keys
#
# Usage:
#   export LLM_PROVIDER=groq
#   export GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
#   bun run start
#
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx


# ============================================================================
# OPTION 2: Ollama (Local LLM)
# ============================================================================
# Free, offline, local privacy. Requires Ollama installation.
# Install: https://ollama.ai/download
#
# Usage:
#   ollama serve  (in another terminal)
#   export LLM_PROVIDER=ollama
#   bun run start
#
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=mistral


# ============================================================================
# OPTION 3: OpenAI (Best Quality)
# ============================================================================
# Costs money but best quality answers.
# Get API key: https://platform.openai.com/api-keys
#
# Usage:
#   export LLM_PROVIDER=openai
#   export OPENAI_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxx
#   bun run start
#
OPENAI_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxx


# ============================================================================
# Optional Settings (apply to all providers)
# ============================================================================

# Delay between requests (in milliseconds)
# Default: 1000 (1 second)
# Increase if you hit rate limits: 2000, 3000, etc.
REQUEST_DELAY_MS=1000

# Skip failed questions instead of exiting
# Default: false
# Set to true if you want to skip questions on rate limit/errors
SKIP_ON_RATE_LIMIT=false

# Maximum questions to process per run
# Default: 500
# Higher values increase API costs but allow processing longer quizzes
MAX_QUESTIONS=500

# Output directory for review mode and auto mode answer files
# Default: ./quiz-answers
# The tool will create this directory if it doesn't exist
ANSWER_FILES_DIR=./quiz-answers
