# bk-quiz configuration
# Run "bun run setup" to create this file interactively

# Choose ONE provider: groq (recommended), openai, or ollama
LLM_PROVIDER=groq

# Provider API keys (only fill the one you're using)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxx

# Ollama settings (only if using Ollama)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=mistral

# Optional tuning
REQUEST_DELAY_MS=1000
MAX_QUESTIONS=500
